# Normalize line endings for cross-platform collaboration
* text=auto eol=lf

# Shell scripts must stay LF
*.sh text eol=lf

# Windows scripts may use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binaries
*.exe binary
*.dll binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
